# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Default sender shown in outgoing emails
DEFAULT_FROM="Your App <your-email@gmail.com>"

# Optional API key (leave empty to disable auth)
API_KEY=change-me-to-a-secret-key

# Server port
PORT=3000
